{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "bss.bssfSpecificationEnquiry.scheduleDefinition.readResponse.1.json#",
  "description": "Schedule Definition Specification.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "scheduleDefinitionType": {
      "description": "The type of schedule definition.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 32
    },
    "recurrenceFreq": {
      "description": "Recurrence frequency of schedule definition.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "frequencyType": {
          "description": "Frequency type of recurrence frequency.",
          "type": "string",
          "enum": [
            "DAILY",
            "WEEKLY",
            "MONTHLY",
            "YEARLY"
          ]
        },
        "recurrenceCount": {
          "description": "Recurrence count of a schedule definition.",
          "type": "integer",
          "minimum": 1,
          "maximum": 9223372036854775806
        },
        "recurrenceInterval": {
          "description": "Recurrence interval of a schedule definition.",
          "type": "integer",
          "minimum": 1,
          "maximum": 9223372036854775806
        },
        "time": {
          "description": "A time with a predefined time zone.",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "time": {
              "description": "This type defines a time value based on the definition found at http://www.w3.org/TR/xmlschema-2/#time. Fractional seconds with three decimals are mandatory. Leap seconds are not supported. Example values are \u002714:35:05.003\u0027. The latter example is the recommended format.",
              "type": "string",
              "pattern": "^(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000)?)$"
            },
            "timeZone": {
              "description": "This specifies which predefined time zone to be used.",
              "type": "string",
              "enum": [
                "HOME_TIME_ZONE"
              ]
            }
          }
        },
        "weekly": {
          "description": "Schedule definition by weekly.",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "recurrenceByDay": {
              "description": "Recurrence by weekdays.",
              "type": "array",
              "items": {
                "description": "Recurrence By Day.",
                "type": "string",
                "enum": [
                  "MONDAY",
                  "TUESDAY",
                  "WEDNESDAY",
                  "THURSDAY",
                  "FRIDAY",
                  "SATURDAY",
                  "SUNDAY"
                ]
              }
            }
          }
        },
        "monthly": {
          "description": "Schedule definition by monthly.",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "monthDayNumber": {
              "description": "Monthly schedule definition by month day number.",
              "type": "array",
              "items": {
                "description": "List of days of month.",
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "offsetType": {
                    "description": "Offset to specify if day should count from start or end.",
                    "type": "string",
                    "enum": [
                      "COUNT_FROM_START",
                      "COUNT_FROM_END"
                    ]
                  },
                  "recurrenceByMonthDay": {
                    "description": "Recurrence by month day.",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 28
                  }
                }
              }
            },
            "weekdayOfMonth": {
              "description": "Schedule definition by weekday of month.",
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "recurrenceByDay": {
                  "description": "Recurrence by weekday.",
                  "type": "string",
                  "enum": [
                    "MONDAY",
                    "TUESDAY",
                    "WEDNESDAY",
                    "THURSDAY",
                    "FRIDAY",
                    "SATURDAY",
                    "SUNDAY"
                  ]
                },
                "weekNumber": {
                  "description": "Recurrence by week number of the month.",
                  "type": "string",
                  "enum": [
                    "FIRST",
                    "SECOND",
                    "THIRD",
                    "FOURTH",
                    "LAST"
                  ]
                }
              }
            }
          }
        },
        "yearly": {
          "description": "Recurrence frequency of schedule definition.",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "weekdaysOfYear": {
              "description": "Yearly schedule definition by weekdays of year.",
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "recurrenceByDay": {
                  "description": "Recurrence by weekdays.",
                  "type": "array",
                  "items": {
                    "description": "Recurrence By Day.",
                    "type": "string",
                    "enum": [
                      "MONDAY",
                      "TUESDAY",
                      "WEDNESDAY",
                      "THURSDAY",
                      "FRIDAY",
                      "SATURDAY",
                      "SUNDAY"
                    ]
                  }
                },
                "weekNumber": {
                  "description": "Week number of the year.",
                  "type": "array",
                  "items": {
                    "description": "List of week number of the year.",
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "offsetType": {
                        "description": "Offset to specify if day should count from start or end.",
                        "type": "string",
                        "enum": [
                          "COUNT_FROM_START",
                          "COUNT_FROM_END"
                        ]
                      },
                      "recurrenceByWeekNo": {
                        "description": "Recurrence by week number of the year.",
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 52
                      }
                    }
                  }
                }
              }
            },
            "daysOfMonth": {
              "description": "Schedule definition by days of month.",
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "monthDayNumber": {
                  "description": "Recurrence by month day.",
                  "type": "array",
                  "items": {
                    "description": "List of days of month.",
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "offsetType": {
                        "description": "Offset to specify if day should count from start or end.",
                        "type": "string",
                        "enum": [
                          "COUNT_FROM_START",
                          "COUNT_FROM_END"
                        ]
                      },
                      "recurrenceByMonthDay": {
                        "description": "Recurrence by month day.",
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 28
                      }
                    }
                  }
                },
                "recurrenceByMonth": {
                  "description": "Recurrence by months.",
                  "type": "array",
                  "items": {
                    "description": "recurrence by year months.",
                    "type": "string",
                    "enum": [
                      "JANUARY",
                      "FEBRUARY",
                      "MARCH",
                      "APRIL",
                      "MAY",
                      "JUNE",
                      "JULY",
                      "AUGUST",
                      "SEPTEMBER",
                      "OCTOBER",
                      "NOVEMBER",
                      "DECEMBER"
                    ]
                  }
                }
              }
            },
            "daysOfYear": {
              "description": "Yearly schedule definition by days of year.",
              "type": "array",
              "items": {
                "description": "Yearly schedule definition by days of year.",
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "offsetType": {
                    "description": "Offset to specify if day should count from start or end.",
                    "type": "string",
                    "enum": [
                      "COUNT_FROM_START",
                      "COUNT_FROM_END"
                    ]
                  },
                  "recurrenceByYearDay": {
                    "description": "Recurrence by year day.",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 366
                  }
                }
              }
            }
          }
        }
      }
    },
    "id": {
      "description": "Unique identifier of the specification.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "externalId": {
      "description": "Identifier of the specification in an external system.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "name": {
      "description": "Name given to this specification. Not guaranteed to be unique.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256
    },
    "description": {
      "description": "Description of this specification.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 512
    },
    "version": {
      "description": "Entity specification version.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "validFor": {
      "description": "StartDateTime must be earlier than EndDateTime.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "startDateTime": {
          "description": "Start dateTime of the time period. The value is inclusive, including the starting point of the interval. The pattern is based on the definition found at http://www.w3.org/TR/xmlschema-2/#dateTime.",
          "type": "string",
          "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
          "format": "date-time"
        },
        "endDateTime": {
          "description": "End dateTime of the time period. The value is exclusive, excluding the ending point of the interval. The pattern is based on the definition found at http://www.w3.org/TR/xmlschema-2/#dateTime.",
          "type": "string",
          "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
          "format": "date-time"
        }
      }
    },
    "lastUpdate": {
      "description": "Date and time of the last update of this specification.",
      "type": "string",
      "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
      "format": "date-time"
    },
    "lifecycleStatus": {
      "description": "Used to indicate the current lifecycle status of this specification.",
      "type": "string",
      "enum": [
        "ACTIVE"
      ]
    }
  }
}