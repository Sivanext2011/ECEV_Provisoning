{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "bss.bssfSpecificationEnquiry.referenceDataListSpecification.readResponse.1.json#",
  "description": "Data structure for reference data list specification describing the data layout for a reference data list.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "columnDefinition": {
      "description": "The definitions of all the columns in this reference data list specification.",
      "type": "array",
      "items": {
        "description": "Data structure for cell specification.",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "description": "The id of the cell specification.",
            "type": "string",
            "pattern": "^(?\u003d\\s*\\S).*$",
            "maxLength": 256
          },
          "name": {
            "description": "The name of the cell specification.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 256
          },
          "description": {
            "description": "The description of the cell specification.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 256
          },
          "type": {
            "description": "The data type of the cell specification.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 128
          },
          "isPublicKey": {
            "description": "Returns true if is represents a public key.",
            "type": "boolean"
          },
          "comprisedOf": {
            "description": "List of cell specification.",
            "type": "array",
            "items": {
              "$ref": "#/properties/columnDefinition/items"
            }
          }
        }
      }
    },
    "id": {
      "description": "Unique identifier of the specification.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "externalId": {
      "description": "Identifier of the specification in an external system.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "name": {
      "description": "Name given to this specification. Not guaranteed to be unique.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256
    },
    "description": {
      "description": "Description of this specification.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 512
    },
    "version": {
      "description": "Entity specification version.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "validFor": {
      "description": "StartDateTime must be earlier than EndDateTime.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "startDateTime": {
          "description": "Start dateTime of the time period. The value is inclusive, including the starting point of the interval. The pattern is based on the definition found at http://www.w3.org/TR/xmlschema-2/#dateTime.",
          "type": "string",
          "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
          "format": "date-time"
        },
        "endDateTime": {
          "description": "End dateTime of the time period. The value is exclusive, excluding the ending point of the interval. The pattern is based on the definition found at http://www.w3.org/TR/xmlschema-2/#dateTime.",
          "type": "string",
          "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
          "format": "date-time"
        }
      }
    },
    "lastUpdate": {
      "description": "Date and time of the last update of this specification.",
      "type": "string",
      "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
      "format": "date-time"
    },
    "lifecycleStatus": {
      "description": "Used to indicate the current lifecycle status of this specification.",
      "type": "string",
      "enum": [
        "ACTIVE"
      ]
    }
  }
}