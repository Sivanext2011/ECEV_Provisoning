{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "bss.bssfFinancialTransactionManagement.financialTask.createResponse.1.json#",
  "description": "Financial task enquiry provides the ability to obtain financial transaction details for a customer.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {
      "description": "Unique identifier for the financial task.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "financialTransaction": {
      "description": "Financial transaction enquiry provides the ability to obtain financial details for a customer.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "description": "Unique identifier for the financial transaction.",
          "type": "string",
          "pattern": "^(?\u003d\\s*\\S).*$",
          "maxLength": 256
        },
        "entryDate": {
          "description": "The entry date of financial transaction.",
          "type": "string",
          "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
          "format": "date-time"
        },
        "transactionDate": {
          "description": "The transaction date of financial transaction.",
          "type": "string",
          "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
          "format": "date-time"
        }
      }
    }
  }
}