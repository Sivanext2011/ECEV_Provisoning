{
  "$schema": "http://json-schema.org/draft-03/schema",
  "id": "bss.bssfRecurrenceEnquiry.recurrenceInformation.readResponse.1.json#",
  "description": "Recurrence information for recurring events for products.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nextRecurrenceAttempt": {
      "description": "Indicates the next recurrence attempt.",
      "type": "string",
      "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
      "format": "date-time"
    },
    "customerId": {
      "description": "A unique customer ID for the customer to use for the related recurrence information.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "customerExternalId": {
      "description": "A customer ID provided by an external system for the customer for the related recurrence information.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "contractId": {
      "description": "A unique contract ID for the customer for the related recurrence information.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "contractExternalId": {
      "description": "A contract ID provided by an external system for the contract for the related recurrence information.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "productId": {
      "description": "A unique product ID for the product for the related recurrence information.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256,
      "deprecated": true
    },
    "productExternalId": {
      "description": "A product ID provided by an external system for the product for the related recurrence information.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256,
      "deprecated": true
    },
    "recurrenceScheduleInformation": {
      "description": "Recurrence schedule information.",
