      "items": {
        "description": "Recurrence schedule information.",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "lastEvaluationDate": {
            "description": "Last evaluation date.",
            "type": "string",
            "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
            "format": "date-time"
          },
          "nextEvaluationDate": {
            "description": "Next evaluation date.",
            "type": "string",
            "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
            "format": "date-time"
          },
          "scheduleDefinitionId": {
            "description": "A unique identifier of the schedule definition for the recurrence.",
            "type": "string",
            "pattern": "^(?\u003d\\s*\\S).*$",
            "maxLength": 256
          },
          "scheduleDefinitionExternalId": {
            "description": "An external identifier of the schedule definition for the recurrence.",
            "type": "string",
            "pattern": "^(?\u003d\\s*\\S).*$",
            "maxLength": 256
          },
          "price": {
            "description": "Product price details corresponding to a product related to a contract.",
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "productOfferingPriceId": {
                "description": "The product offering price identifier.",
                "type": "string",
                "pattern": "^(?\u003d\\s*\\S).*$",
                "maxLength": 256
              },
              "productOfferingPriceExternalId": {
                "description": "The product offering price external identifier.",
                "type": "string",
                "pattern": "^(?\u003d\\s*\\S).*$",
                "maxLength": 256
              }
            }
          },
          "product": {
            "description": "Product Reference.",
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "id": {
                "description": "ID of the product.",
                "type": "string",
                "pattern": "^(?\u003d\\s*\\S).*$",
                "maxLength": 256
              },
              "externalId": {
                "description": "ExternalId of the product.",
                "type": "string",
                "pattern": "^(?\u003d\\s*\\S).*$",
                "maxLength": 256
              }
            }
          }
        }
      }
    }
  }
