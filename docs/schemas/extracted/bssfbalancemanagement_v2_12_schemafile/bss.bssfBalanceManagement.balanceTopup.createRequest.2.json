{
  "$schema": "http://json-schema.org/draft-03/schema",
  "id": "bss.bssfBalanceManagement.balanceTopup.createRequest.2.json#",
  "description": "Perform balance top up.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "triggerTime": {
      "description": "The timestamp indicating the time of balance top up. DateTime according to W3. yyyy-MM-ddThh:MM:ss(.SSS)TZD, where TZD \u003d Z or +hh:mm or -hh:mm (eg 1997-07-16T19:20:30.45+01:00).",
      "type": "string",
      "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
      "format": "date-time"
    },
    "customerId": {
      "description": "A unique customer ID for the customer for which balance top up is done.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256,
      "deprecated": true
    },
    "customerExternalId": {
      "description": "A customer ID provided by an external system for the customer for which balance balance top up is done.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256,
      "deprecated": true
    },
    "relatedParty": {
      "description": "Related Party or Party Role",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "@referredType": {
          "description": "Referred Type.",
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "externalId": {
          "description": "External identifier of the party or party role.",
          "type": "string",
          "pattern": "^(?\u003d\\s*\\S).*$",
          "maxLength": 256
        },
        "id": {
          "description": "Unique identifier of the party or party role.",
          "type": "string",
          "pattern": "^(?\u003d\\s*\\S).*$",
          "maxLength": 256
        }
      }
    },
    "contractId": {
      "description": "A unique contract ID for the contract on which balance top up is done.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "contractExternalId": {
      "description": "A contract ID provided by an external system for the contract on which balance top up is done.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "communicationIdType": {
      "description": "Value of Communication type, for example E.164.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 32
    },
    "communicationId": {
      "description": "Communication ID value.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 512
    },
    "accessChannel": {
      "description": "The access channel used for the balance top up.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256
    },
    "paymentMethod": {
      "description": "Payment method control information.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "description": "Type of payment method.",
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "details": {
          "description": "Balance Topup detail information.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "refillProfileId": {
              "description": "Refill Profile Id.",
              "type": [
                "string",
                "null"
              ],
              "maxLength": 128
            },
            "voucherActivationCode": {
              "description": "Voucher Activation Code.",
              "type": [
                "string",
                "null"
              ],
              "maxLength": 128
            }
          }
        }
      }
    },
    "amount": {
      "description": "Amount representation.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "number": {
          "description": "Carrying value.",
          "type": "integer",
          "minimum": -9223372036854775807,
          "maximum": 9223372036854775806
        },
        "decimalPlaces": {
          "description": "Number of decimals in the value.",
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        }
      }
    },
    "unitOfMeasure": {
      "description": "Unit of measure for the top up amount.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 32
    },
    "additionalInfo": {
      "description": "Additional information associated with the balance top up activity.",
      "type": "array",
      "items": {
        "description": "Key value.",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "key": {
            "description": "Represents the data key.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 256
          },
          "value": {
            "description": "Represents the data value.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 256
          }
        }
      }
    }
  }
}