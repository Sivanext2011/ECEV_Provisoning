{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "bss.bssfPartnerSettlingManagement.partnerSettlementNoteOnDemand.createRequest.1.json#",
  "description": "Creating a partner settlement note on demand (off-cycle).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "relatedParty": {
      "description": "Related Party or Party Role",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "@referredType": {
          "description": "Referred Type.",
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128
        },
        "externalId": {
          "description": "External identifier of the party or party role.",
          "type": "string",
          "pattern": "^(?\u003d\\s*\\S).*$",
          "maxLength": 256
        },
        "id": {
          "description": "Unique identifier of the party or party role.",
          "type": "string",
          "pattern": "^(?\u003d\\s*\\S).*$",
          "maxLength": 256
        }
      }
    },
    "settlementAccount": {
      "description": "Settlement Account Reference.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "externalId": {
          "description": "External identifier of the settlement account.",
          "type": "string",
          "pattern": "^(?\u003d\\s*\\S).*$",
          "maxLength": 256
        },
        "id": {
          "description": "Unique identifier of the settlement account.",
          "type": "string",
          "pattern": "^(?\u003d\\s*\\S).*$",
          "maxLength": 256
        }
      }
    },
    "accumulatedPartnerSettlementsUpToDate": {
      "description": "Include accumulated partner settlements up until this date and time.",
      "type": "string",
      "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
      "format": "date-time"
    },
    "mailingDateOffset": {
      "description": "Offset compared to the current date for calculating the mailing date (in days).",
      "type": "string",
      "pattern": "^(-?)P(?\u003d\\d|T\\d)(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+(?:\\.\\d{1,3})?)S)?)?$"
    },
    "paymentDueDateOffset": {
      "description": "Offset compared to the mailing date for calculating the payment due date (in days).",
      "type": "string",
      "pattern": "^(-?)P(?\u003d\\d|T\\d)(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+(?:\\.\\d{1,3})?)S)?)?$"
    },
    "reason": {
      "description": "Reason of generating the partner settlement note on demand.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256
    }
  }
}