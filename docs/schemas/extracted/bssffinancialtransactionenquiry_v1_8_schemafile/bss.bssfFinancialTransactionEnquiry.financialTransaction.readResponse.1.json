{
  "$schema": "http://json-schema.org/draft-03/schema",
  "id": "bss.bssfFinancialTransactionEnquiry.financialTransaction.readResponse.1.json#",
  "description": "A financial transaction array representing multiple financial transaction.",
  "type": "array",
  "items": {
    "description": "Financial transaction enquiry provides the ability to obtain financial details for a customer.",
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "id": {
        "description": "Unique identifier for the financial transaction.",
        "type": "string",
        "pattern": "^(?\u003d\\s*\\S).*$",
        "maxLength": 256
      },
      "relatedParty": {
        "description": "Reference to related party roles",
        "type": "array",
        "items": {
          "description": "Related Party or Party Role",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "@referredType": {
              "description": "Referred Type.",
              "type": [
                "string",
                "null"
              ],
              "maxLength": 128
            },
            "externalId": {
              "description": "External identifier of the party or party role.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            },
            "id": {
              "description": "Unique identifier of the party or party role.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            }
          }
        }
      },
      "financialTransactionSpecification": {
        "description": "Financial Transaction Specification Reference.",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "externalId": {
            "description": "External identifier for the Financial Transaction Specification.",
            "type": "string",
            "pattern": "^(?\u003d\\s*\\S).*$",
            "maxLength": 256
          },
          "id": {
            "description": "Unique identifier for the Financial Transaction Specification.",
            "type": "string",
            "pattern": "^(?\u003d\\s*\\S).*$",
            "maxLength": 256
          }
        }
      },
      "characteristic": {
        "description": "Reference to characteristic value  with no validFor.",
        "type": "array",
        "items": {
          "description": "A value of a Characteristic.",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "charSpecId": {
              "description": "The ID of the characteristic specification.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            },
            "charSpecExternalId": {
              "description": "The External ID of the characteristic specification.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            },
            "value": {
              "description": "The versions of the value.",
              "type": "array",
              "items": {
                "description": "The versions of the value.",
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "value": {
                    "description": "The value.",
                    "type": [
                      "string",
                      "null"
                    ],
                    "maxLength": 256
                  },
                  "unitOfMeasure": {
                    "description": "The unit of measure of the value.",
                    "type": [
                      "string",
                      "null"
                    ],
                    "maxLength": 32
                  }
                }
              }
            }
          }
        }
      },
      "financialEntry": {
        "description": "Reference to financial entry",
        "type": "array",
        "items": {
          "description": "Financial Entry Reference.",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "financialHeaderExternalId": {
              "description": "External identifier for the Financial Header.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            },
            "financialHeaderId": {
              "description": "Unique identifier for the Financial Header.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            },
            "financialEntryExternalId": {
              "description": "External identifier for the Financial Entry.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            },
            "financialEntryId": {
              "description": "Unique identifier for the Financial Entry.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            }
          }
        }
      },
      "paymentInstructionRef": {
        "description": "Reference to payment instruction",
        "type": "array",
        "items": {
          "description": "Payment Instruction Reference.",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "id": {
              "description": "Unique identifier for the Payment Instruction.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            }
          }
        }
      },
      "entryDate": {
        "description": "The entry date of financial transaction.",
        "type": "string",
        "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
        "format": "date-time"
      },
      "sourceName": {
        "description": "The source name of financial transaction.",
        "type": [
          "string",
          "null"
        ],
        "maxLength": 256
      },
      "transactionDate": {
        "description": "The transaction date of financial transaction.",
        "type": "string",
        "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
        "format": "date-time"
      },
      "transactionType": {
        "description": "The transaction type of financial transaction.",
        "type": [
          "string",
          "null"
        ],
        "maxLength": 256
      }
    }
  }
}