{
  "$schema": "http://json-schema.org/draft-03/schema",
  "id": "bss.bssfFinancialTransactionEnquiry.paymentInstruction.readResponse.1.json#",
  "description": "A  payment instruction array representing multiple payment instruction.",
  "type": "array",
  "items": {
    "description": "Payment Instruction.",
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "id": {
        "description": "Unique identifier for the payment instruction.",
        "type": "string",
        "pattern": "^(?\u003d\\s*\\S).*$",
        "maxLength": 256
      },
      "creationDate": {
        "description": "The creation date of payment instruction.",
        "type": "string",
        "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
        "format": "date-time"
      },
      "amount": {
        "description": "The versions of the value.",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "creditDebitFlag": {
            "description": "The flag for credit and debit monetary amount",
            "type": "string",
            "enum": [
              "CREDIT",
              "DEBIT"
            ]
          },
          "currencyAmount": {
            "description": "The versions of the value.",
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "value": {
                "description": "Amount representation.",
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "number": {
                    "description": "Carrying a positive value.",
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9223372036854775806
                  },
                  "decimalPlaces": {
                    "description": "Number of decimals in the value.",
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 6
                  }
                }
              },
              "unitOfMeasure": {
                "description": "The unit of measure of the value.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 32
              }
            }
          }
        }
      },
      "reasonCode": {
        "description": "The reason code of payment instruction.",
        "type": [
          "string",
          "null"
        ],
        "maxLength": 128
      },
      "type": {
        "description": "The type of payment instruction.",
        "type": [
          "string",
          "null"
        ],
        "maxLength": 256
      },
      "status": {
        "description": "Structure of one status version element.",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "reason": {
            "description": "The reason for the new status version.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 256
          },
          "status": {
            "description": "The status for the given time period.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 256
          }
        }
      },
      "relatedParty": {
        "description": "Reference to related party roles",
        "type": "array",
        "items": {
          "description": "Related Party or Party Role",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "@referredType": {
              "description": "Referred Type.",
              "type": [
                "string",
                "null"
              ],
              "maxLength": 128
            },
            "externalId": {
              "description": "External identifier of the party or party role.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            },
            "id": {
              "description": "Unique identifier of the party or party role.",
              "type": "string",
              "pattern": "^(?\u003d\\s*\\S).*$",
              "maxLength": 256
            }
          }
        }
      },
      "financialHeader": {
        "description": "Financial Header Reference.",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "externalId": {
            "description": "External identifier for the Financial Header.",
            "type": "string",
            "pattern": "^(?\u003d\\s*\\S).*$",
            "maxLength": 256
          },
          "id": {
            "description": "Unique identifier for the Financial Header.",
            "type": "string",
            "pattern": "^(?\u003d\\s*\\S).*$",
            "maxLength": 256
          }
        }
      }
    }
  }
}