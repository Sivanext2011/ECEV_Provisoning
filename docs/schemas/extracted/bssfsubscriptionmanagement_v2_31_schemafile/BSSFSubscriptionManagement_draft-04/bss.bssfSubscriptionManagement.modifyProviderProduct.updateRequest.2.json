      "maxLength": 256
    },
    "customerExternalId": {
      "description": "Represents the provider external customer Id.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "contractId": {
      "description": "Represents the provider contract Id.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "contractExternalId": {
      "description": "Represents the provider external contract Id.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "productId": {
      "description": "Represents the provider product id.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "productExternalId": {
