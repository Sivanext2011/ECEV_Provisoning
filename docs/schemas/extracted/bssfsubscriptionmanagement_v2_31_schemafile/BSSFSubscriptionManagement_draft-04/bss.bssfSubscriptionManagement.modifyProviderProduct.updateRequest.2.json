      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "communicationIdType": {
      "description": "Value of provider Communication type.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 32
