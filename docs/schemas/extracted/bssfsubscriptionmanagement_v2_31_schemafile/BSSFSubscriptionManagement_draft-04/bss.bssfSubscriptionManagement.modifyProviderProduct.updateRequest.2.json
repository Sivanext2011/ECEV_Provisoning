{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "bss.bssfSubscriptionManagement.modifyProviderProduct.updateRequest.2.json#",
  "description": "Represents consumer product(s) on behalf of a Provider",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "customerId": {
      "description": "Represents the provider customer Id.",
      "type": "string",
