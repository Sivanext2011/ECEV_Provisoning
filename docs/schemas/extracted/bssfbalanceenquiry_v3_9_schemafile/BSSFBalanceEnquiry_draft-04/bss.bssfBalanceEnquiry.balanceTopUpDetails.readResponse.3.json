{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "bss.bssfBalanceEnquiry.balanceTopUpDetails.readResponse.3.json#",
  "description": "Balance topup details.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "fraudAttempts": {
      "description": "Number of detected fraud attempts.",
      "type": "integer",
      "minimum": -2147483648,
      "maximum": 2147483647
    },
    "fraudThreshold": {
      "description": "Fraud attempts Threshold.",
      "type": "integer",
      "minimum": -2147483648,
      "maximum": 2147483647
    },
    "blockedUntil": {
      "description": "The balance top up service is blocked up until this point in time.",
      "type": "string",
      "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
      "format": "date-time"
    },
    "resourceFacingServiceSpecId": {
      "description": "A unique reference to the Resource Facing Service Specification.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "resourceFacingServiceSpecExternalId": {
      "description": "An external reference to the Resource Facing Service Specification.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    }
  }
}