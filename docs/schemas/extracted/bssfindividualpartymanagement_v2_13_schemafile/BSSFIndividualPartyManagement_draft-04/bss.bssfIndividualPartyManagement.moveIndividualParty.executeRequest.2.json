      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "partitionId": {
      "description": "The target partition for this indivual party.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 32
    },
    "siteName": {
      "description": "The target site name for this indivual party.",
      "type": [
        "string",
        "null"
      ],
      "maxLength": 32
    }
  }
}