{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "bss.BSSFSessionManagement.PolicySession.createRequest.1.json#",
  "description": "Data structure for policy and charging session.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "communicationIdentity": {
      "description": "Communication ID type.",
      "type": "array",
      "items": {
        "description": "Represent Communication with id \u0026 type",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "idType": {
            "description": "Communication ID type.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 32
          },
          "id": {
            "description": "Communication ID value.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 512
          }
        }
      }
    },
    "policySession": {
      "description": "This is list of policy session.",
      "type": "array",
      "items": {
        "description": "Data structure for policy session.",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "policySessionId": {
            "description": "Policy session identifier.",
            "type": [
              "string",
              "null"
            ],
            "maxLength": 256
          },
          "lastModifiedTime": {
            "description": "Last modified date time.",
            "type": "string",
            "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
            "format": "date-time"
          },
          "subscribedPolicyCounter": {
            "description": "This is list of subscribed policy counter.",
            "type": "array",
            "items": {
              "description": "String max 256 characters.",
              "type": [
                "string",
                "null"
              ],
              "maxLength": 256
            }
          },
          "policySessionType": {
            "description": " The type of the policy session.",
            "type": "string",
            "enum": [
              "Sy",
              "ESy",
              "N28",
              "E-N28"
            ]
          },
          "diameterSessionDetail": {
            "description": "Data structure for diameter session details.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "policyClientDiameterRealm": {
                "description": "Diameter Realm of the policy client.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 256
              },
              "policyClientDiameterHost": {
                "description": "Diameter Realm of the policy client.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 256
              },
              "diameterSessionOriginState": {
                "description": "Diameter session origin state.",
                "type": "integer",
                "minimum": 1,
                "maximum": 52
              }
            }
          },
          "sbiSessionDetail": {
            "description": "Data structure for policy session.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "supi": {
                "description": "Subcriber permanent identifier.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 256
              },
              "notifUri": {
                "description": "callback uri associated with the session.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 256
              },
              "notificationCorrelationId": {
                "description": "Notification Correlation Id.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 256
              },
              "subscriptionExpiryTime": {
                "description": "Subscription Expiry Time.",
                "type": "string",
                "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
                "format": "date-time"
              },
              "sbiHeader": {
                "description": "Data structure for sbi header.",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "threegppsbibinding": {
                    "description": "Subcriber permanent identifier.",
                    "type": [
                      "string",
                      "null"
                    ],
                    "maxLength": 256
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}