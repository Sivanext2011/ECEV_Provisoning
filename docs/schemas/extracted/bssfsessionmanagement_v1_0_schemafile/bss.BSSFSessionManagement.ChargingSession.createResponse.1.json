{
  "$schema": "http://json-schema.org/draft-03/schema",
  "id": "bss.BSSFSessionManagement.ChargingSession.createResponse.1.json#",
  "description": "Data structure for policy and charging session.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "customerId": {
      "description": "The customer identifier.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "contractId": {
      "description": "The contract identifier.",
      "type": "string",
      "pattern": "^(?\u003d\\s*\\S).*$",
      "maxLength": 256
    },
    "sbiSessionInfo": {
      "description": "Data structure for sbi session information.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sessionCreationTimeStamp": {
          "description": "Session creation time stamp.",
          "type": "string",
          "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
          "format": "date-time"
        },
        "sbiSession": {
          "description": "This is list of sbi session.",
          "type": "array",
          "items": {
            "description": "Data structure for sbi session.",
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "sessionId": {
                "description": "Sbi session identifier.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 256
              },
              "sessionType": {
                "description": " The type of the sbi session. N28 and E-N28 are policy session type. N40 is charging session type",
                "type": "string",
                "enum": [
                  "N40"
                ]
              },
              "serviceContextId": {
                "description": "Service context identifier.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 256
              }
            }
          }
        }
      }
    },
    "diameterSessionInfo": {
      "description": "Data structure for diameter session information.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sessionCreationTimeStamp": {
          "description": "Session creation time stamp.",
          "type": "string",
          "pattern": "^\\d{4}-(((0[13578]|1[02])-(0[1-9]|[12][0-9]|3[01]))|(02-(0[1-9]|[12][0-9]))|((0[469]|11)-(0[1-9]|[12][0-9]|30)))T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}|(24:00:00.000))(Z|\\+((0[0-9]|1[0-3]):[0-5][0-9]|14:00)|-((0[0-9]|1[0-1]):[0-5][0-9]|12:00))$",
          "format": "date-time"
        },
        "diameterSession": {
          "description": "This is list of diameter session.",
          "type": "array",
          "items": {
            "description": "Data structure for diameter session.",
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "sessionId": {
                "description": "Diameter session identifier.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 256
              },
              "sessionType": {
                "description": " The type of the diameter session. Sy and ESy are policy session type. dcca is charging session type",
                "type": "string",
                "enum": [
                  "dcca"
                ]
              },
              "serviceContextId": {
                "description": "Service context identifier.",
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 256
              }
            }
          }
        }
      }
    }
  }
}